	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#734f9a",
				"fontStyle": "italic"
			}
		},
		{
			"scope": ["constant", "variable.other.constant", "support.constant"],
			"settings": {
				"foreground": "#40c8e8"
			}
		},
		{
			"scope": ["string", "punctuation.definition.string"],
			"settings": {
				"foreground": "#ec7420"
			}
		},
		{
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#8bd450",
				"fontStyle": "bold"
			}
		},
		{
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#965fd4",
				"fontStyle": "bold"
			}
		},
		{
			"scope": ["entity.name.type", "support.type", "support.class"],
			"settings": {
				"foreground": "#3f6d4e",
				"fontStyle": "bold"
			}
		},
		{
			"scope": ["variable", "identifier"],
			"settings": {
				"foreground": "#e8e8e8"
			}
		},
		{
			"scope": ["punctuation", "meta.brace", "meta.delimiter"],
			"settings": {
				"foreground": "#8bd450"
			}
		},
		{
			"scope": ["meta.preprocessor", "keyword.control.directive"],
			"settings": {
				"foreground": "#ec7420"
			}
		},
		{
			"scope": ["entity.other.attribute-name"],
			"settings": {
				"foreground": "#f4b000",
				"fontStyle": "italic"
			}
		}
	],
	"semanticTokenColors": {
		"variable": "#e8e8e8",
		"parameter": "#e8e8e8",
		"function": {
			"foreground": "#8bd450",
			"fontStyle": "bold"
		},
		"class": {
			"foreground": "#3f6d4e",
			"fontStyle": "bold"
		},
		"keyword": "#965fd4"
	}
}
